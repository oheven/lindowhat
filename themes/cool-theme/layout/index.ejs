<div class="post-list">
    <% page.posts.each(function(post, index) { %>
    <article class="post-card" style="--index: <%= index %>">
        <h2>
            <a href="<%- url_for(post.path) %>"><%= post.title %></a>
        </h2>
        <div class="post-meta">
            <span>📅 <%= post.date.format('YYYY-MM-DD') %></span>
            <% if (post.categories && post.categories.length) { %>
            <span>📂 <%= post.categories.map(cat => cat.name).join(', ') %></span>
            <% } %>
        </div>
        <div class="post-excerpt">
            <% if (post.excerpt) { %>
                <%- post.excerpt %>
            <% } else { %>
                <p><%= strip_html(post.content).substring(0, 200) %>...</p>
            <% } %>
        </div>
        <% if (post.tags && post.tags.length) { %>
        <div class="tags">
            <% post.tags.each(function(tag) { %>
            <a class="tag" href="<%- url_for(tag.path) %>"><%= tag.name %></a>
            <% }) %>
        </div>
        <% } %>
    </article>
    <% }) %>
</div>

<% if (page.total > 1) { %>
<nav class="pagination">
    <%- paginator({
        prev_text: '← 上一页',
        next_text: '下一页 →',
        escape: false
    }) %>
</nav>
<% } %>